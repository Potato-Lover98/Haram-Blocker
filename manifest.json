{
  "manifest_version": 3,
  "name": "Ghassil — Haram Blocker",
  "version": "1.0.0",
  "description": "Blocks haram websites, explicit search queries, profanity and inappropriate images. Add your own sites to block.",
  "permissions": ["storage", "webNavigation", "tabs", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lists.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ghassil — Haram Blocker"
  },
  "icons": { "128": "icon.png" },
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
